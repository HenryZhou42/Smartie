<?xml version="1.0" encoding="utf-8"?>
<!--
  MSIX package publish profile.
  dotnet publish src/Smartie.Maui/Smartie.Maui.csproj -f net9.0-windows10.0.19041.0 -p:PublishProfile=win-x64-msix
  Requires Windows App SDK / MSIX tooling (Visual Studio installer: MSIX Packaging Tools).
-->
<Project>
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>x64</Platform>
    <PublishDir>..\..\dist\Smartie-0.9.0-msix\</PublishDir>
    <PublishUrl>..\..\dist\Smartie-0.9.0-msix\</PublishUrl>
    <PublishProtocol>FileSystem</PublishProtocol>
    <TargetFramework>net9.0-windows10.0.19041.0</TargetFramework>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <WindowsPackageType>MSIX</WindowsPackageType>
    <WindowsAppSDKSelfContained>true</WindowsAppSDKSelfContained>
    <GenerateAppxPackageOnBuild>true</GenerateAppxPackageOnBuild>
    <AppxPackageSigningEnabled>false</AppxPackageSigningEnabled>
    <IncludeDebugSymbolsProjectOutputGroup>false</IncludeDebugSymbolsProjectOutputGroup>
    <AppxPackageIncludePrivateSymbols>false</AppxPackageIncludePrivateSymbols>
    <!-- VS may skip rebuild when up-to-date; still publish with win-x64 RID (see FixRidStaticWebAssets.targets). -->
    <DisableFastUpToDateCheck>true</DisableFastUpToDateCheck>
  </PropertyGroup>
</Project>
