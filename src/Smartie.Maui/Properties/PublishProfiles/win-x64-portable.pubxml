<?xml version="1.0" encoding="utf-8"?>
<!--
  Portable Windows x64 publish profile (unpackaged Smartie.exe).
  dotnet publish -p:PublishProfile=win-x64-portable
-->
<Project>
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>x64</Platform>
    <PublishDir>..\..\dist\Smartie-0.9.0-portable\publish\</PublishDir>
    <PublishUrl>..\..\dist\Smartie-0.9.0-portable\publish\</PublishUrl>
    <PublishProtocol>FileSystem</PublishProtocol>
    <TargetFramework>net9.0-windows10.0.19041.0</TargetFramework>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <WindowsPackageType>None</WindowsPackageType>
    <WindowsAppSDKSelfContained>true</WindowsAppSDKSelfContained>
  </PropertyGroup>
</Project>
