@typeparam TValue

@if (Multiline)
{
    <textarea class="smartie-input @AdditionalClass"
              rows="@Rows"
              placeholder="@Placeholder"
              disabled="@Disabled"
              value="@StringValue"
              @oninput="HandleInput"
              @attributes="AdditionalAttributes"></textarea>
}
else
{
    <input type="@Type"
           class="smartie-input @AdditionalClass"
           placeholder="@Placeholder"
           disabled="@Disabled"
           value="@StringValue"
           @oninput="HandleInput"
           @onchange="HandleChange"
           @attributes="AdditionalAttributes" />
}

@code {
    [Parameter] public TValue? Value { get; set; }
    [Parameter] public EventCallback<TValue?> ValueChanged { get; set; }
    [Parameter] public string Type { get; set; } = "text";
    [Parameter] public bool Multiline { get; set; }
    [Parameter] public int Rows { get; set; } = 3;
    [Parameter] public string? Placeholder { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public string? AdditionalClass { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string? StringValue => Value?.ToString();

    private async Task HandleInput(ChangeEventArgs e)
    {
        if (typeof(TValue) == typeof(string))
        {
            await ValueChanged.InvokeAsync((TValue?)(object?)e.Value?.ToString());
        }
    }

    private async Task HandleChange(ChangeEventArgs e)
    {
        if (typeof(TValue) == typeof(string))
        {
            await ValueChanged.InvokeAsync((TValue?)(object?)e.Value?.ToString());
        }
    }
}
