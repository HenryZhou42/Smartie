@page "/about"



<PageTitle>Smartie · About</PageTitle>



<div class="about-page">

    <header class="about-header">

        <p class="edition-badge">@SmartieAppInfo.DisplayTitle</p>

        <h1>@SmartieAppInfo.ProductName</h1>

        <p class="about-tagline">@SmartieAppInfo.Description — local-first, private, and bring-your-own-AI.</p>

        <dl class="about-version">

            <div><dt>Version</dt><dd>@SmartieAppInfo.FullVersion</dd></div>

            <div><dt>Build</dt><dd>@SmartieAppInfo.BuildNumber</dd></div>

            <div><dt>Build date</dt><dd>@SmartieAppInfo.BuildDate</dd></div>

            <div><dt>Edition</dt><dd>@SmartieAppInfo.Edition</dd></div>

            <div><dt>License</dt><dd>@SmartieAppInfo.License</dd></div>

        </dl>

    </header>



    <section class="about-section">

        <h2>Community Edition</h2>

        <ul class="about-list">

            <li>No login, no subscription, no billing</li>

            <li>All conversations and settings stored in local SQLite</li>

            <li>You provide your own API keys (encrypted on this device)</li>

            <li>Gemini, OpenAI, OpenRouter, or Ollama in Settings</li>

            <li>Chat, Knowledge Base, RAG, Memory, Tasks, Files, Plugins, Automations</li>

            <li>No telemetry, no cloud sync, no tracking</li>

        </ul>

    </section>



    <section class="about-section">

        <h2>Your data stays local</h2>

        <p>Smartie Community Edition runs entirely on your machine under <code>%LOCALAPPDATA%\Smartie</code>. Chat history, documents, memories, and encrypted API keys never leave your device except when calling the AI provider you configured.</p>

    </section>



    <section class="about-section">

        <h2>Roadmap</h2>

        <p>Smartie Cloud (hosted sync and managed AI) is a future edition — not required for Community Edition.</p>

    </section>



    <section class="about-section about-links">

        <h2>Links</h2>

        <p><a href="@SmartieAppInfo.GitHubUrl" target="_blank" rel="noopener">GitHub repository</a></p>

    </section>



    <section class="about-section">

        <h2>Credits</h2>

        <p>Built with .NET 9, Blazor, MAUI, EF Core, SQLite, and Semantic Kernel.</p>

    </section>

</div>

